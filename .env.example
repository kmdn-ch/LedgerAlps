# ─── LedgerAlps — Configuration ──────────────────────────────────────────────
# Copier ce fichier : cp .env.example .env
# Ne jamais committer le fichier .env !

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ledgeralps
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ledgeralps

# ─── Sécurité JWT ─────────────────────────────────────────────────────────────
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_in_production_use_32_chars_minimum

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
